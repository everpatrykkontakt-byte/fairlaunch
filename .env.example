# FairLaunch — environment configuration
#
# The skeleton runs fully without any of these set: the chain and data layers
# default to deterministic in-memory adapters (see src/chain and src/data).
# Fill these in only when you wire a real backend / chain implementation.

# --- Chain adapter selection (SERVER) ---
# "mock"       -> deterministic in-memory chain (default, no network, no risk)
# "pumpportal" -> SIMPLE real Pump.fun launch via PumpPortal's API (just signs
#                 a tx PumpPortal builds). Smallest real integration.
# "solana"     -> full mainnet Pump.fun adapter via @pump-fun/pump-sdk.
# ⚠️ "pumpportal" and "solana" MOVE REAL MONEY and are untested here — test with
#    tiny amounts and audit before any public use.
CHAIN_ADAPTER=mock

# Must match CHAIN_ADAPTER for the frontend to sign real deposits (CLIENT).
# "solana" makes Connect use Phantom and backers sign real SOL transfers.
NEXT_PUBLIC_CHAIN_ADAPTER=mock

# --- Data store selection ---
# "memory" -> in-process store, reseeded on boot (default)
# "postgres" -> your own Postgres-backed repository (implement src/data/pgStore.ts)
DATA_STORE=memory

# --- Solana (only used by the solana adapter) ---
# A real, ideally paid RPC endpoint (public RPC will rate-limit launches).
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=
# Platform escrow wallet secret key, base58. Pays gas top-ups + fee payouts.
# NEVER commit a real value. Keep this out of the client bundle.
ESCROW_PRIVATE_KEY=
# Optional address-lookup-table to compress the atomic create+buy tx
# (recommended on mainnet to stay within tx size limits).
PUMP_ALT_ADDRESS=

# 32-byte secret, base64. Encrypts per-pool wallet keys at rest (AES-256-GCM).
# NEVER commit a real value. Generate: openssl rand -base64 32
POOL_KEY_ENCRYPTION_KEY=

# --- Operational ---
CRON_SECRET=
NEXT_PUBLIC_APP_NAME=FairLaunch
